# Copy .env.example to .env and adjust as needed.
# This file is encrypted with dotenvx (see README "Secrets & encryption")
# and is sage to commit - only encrypted values live here, never plaintext.

# Which environment block in src/config/environments.ts to use
ENV=production

# Application under test
BASE_URL=https://www.saucedemo.com/
API_URL=https://jsonplaceholder.typicode.com

# Credentials (these are SauceDemo's public demo credentials; replace per environment )
SAUCE_USERNAME=<standard-user-username>
SAUCE_PASSWORD=<shared-password>

# Other SauceDemo demo users (see src/data/Users.ts); share the password above
SAUCE_LOCKED_USERNAME=<locked-user-username>
SAUCE_PROBLEM_USERNAME=<problem-user-username>
SAUCE_PERFORMANCE_USERNAME=<performance-user-username>